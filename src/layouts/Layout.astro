---
import "../styles/global.css";
import Nav from "../components/Nav.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Rudy Gault - Portfolio",
  description = "Alternant infrastructure & développement - projets école, projets personnels et alternance.",
  image = "/avatar.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/avatar.png" />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="fr_FR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <script is:inline>
      const stored = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      const theme = stored || (prefersDark ? "dark" : "light");
      if (theme !== "light") document.documentElement.classList.add(theme);
    </script>
  </head>
  <body class="min-h-screen bg-[var(--bg)] text-[var(--fg)]">
    <Nav />
    <main class="mx-auto max-w-5xl px-4 py-8 sm:px-6 sm:py-12">
      <slot />
    </main>
    <footer class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 border-t border-[var(--border)] px-4 py-8 text-sm text-[var(--fg-muted)] sm:px-6">
      <p>© {new Date().getFullYear()} Rudy Gault</p>
      <div class="flex items-center gap-4">
        <a href="mailto:gault.rudy@gmail.com" class="transition-colors hover:text-[var(--accent)]">
          Email
        </a>
        <a
          href="https://www.linkedin.com/in/rudy-gault/"
          target="_blank"
          rel="noreferrer"
          class="transition-colors hover:text-[var(--accent)]"
        >
          LinkedIn
        </a>
      </div>
    </footer>
  </body>
</html>
